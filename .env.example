# Roll Tracker — Root Environment (.env.example)
# Copy to .env and fill in values. Do NOT commit .env.

# --- Supabase Remote ---
# SUPABASE_URL: project_url from db_pwd.json
# SUPABASE_SERVICE_ROLE_KEY: JWT-format service role key from Dashboard > Settings > API Keys
#   (NOT the sb_secret_ format — PostgREST requires classic JWT eyJ... keys)
# SUPABASE_DB_URL: Use Session pooler URL (port 5432) not direct connection (IPv6 only, fails in Docker).
#   Format: postgresql://postgres.<project_ref>:[password]@aws-1-us-east-1.pooler.supabase.com:5432/postgres
SUPABASE_URL=https://<project_id>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=<JWT service_role key from dashboard>
SUPABASE_DB_URL=postgresql://postgres.<project_ref>:<password>@aws-1-us-east-1.pooler.supabase.com:5432/postgres
SUPABASE_STORAGE_BUCKET=match-clips

# --- Nest Recorder ---
GYM_ID=<gym_uuid from gyms table>
TZ=America/New_York
SEG_SECONDS=150
# CONFIG_SOURCE=env
# SCHEDULE_JSON={"timezone":"America/New_York","schedules":[{"days":["Mon","Tue","Wed","Thu","Fri"],"start":"20:00","end":"20:30"}]}

# --- Processor (native execution via services/processor/run_local.sh) ---
SCAN_ROOT=data/raw/nest
OUTPUT_ROOT=outputs
POLL_INTERVAL_SECONDS=30
MAX_CLIP_AGE_HOURS=6
# MAX_WORKERS=3
# PARALLEL_DEVICE=cpu
# SEQUENTIAL_DEVICE=auto

# --- Uploader ---
UPLOADER_SCAN_ROOT=/app/outputs
UPLOADER_POLL_SECONDS=60
UPLOADER_DELETE_LOCAL=false
