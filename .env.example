# Roll Tracker — Root Environment (.env.example)
# Copy to .env and fill in values. Do NOT commit .env.
# Used by: docker compose up (root-level compose for all services)

# --- Supabase Remote ---
# Values from backend/supabase/db_pwd.json:
#   SUPABASE_URL           = project_url field
#   SUPABASE_SERVICE_ROLE_KEY = secret_key field (privileged, server-side only)
#   SUPABASE_DB_URL        = direct_connection_string field (replace [YOUR-PASSWORD] with password field)
SUPABASE_URL=https://<project_id>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=<secret_key from db_pwd.json>
SUPABASE_DB_URL=<direct_connection_string from db_pwd.json>

# Storage
SUPABASE_STORAGE_BUCKET=match-clips

# --- Nest Recorder ---
GYM_ID=<gym_uuid from gyms table>
TZ=America/New_York
SEG_SECONDS=150
# SCHED_DAILY_HHMM=20:00

# --- Processor ---
SCAN_ROOT=/app/data/raw/nest
OUTPUT_ROOT=/app/outputs
POLL_INTERVAL_SECONDS=30
# RUN_UNTIL=D6
MAX_CLIP_AGE_HOURS=6

# --- Uploader ---
UPLOADER_SCAN_ROOT=/app/outputs
UPLOADER_POLL_SECONDS=60
UPLOADER_DELETE_LOCAL=false
