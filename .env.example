# Roll Tracker — Root Environment (.env.example)
# Copy to .env and fill in values. Do NOT commit .env.
# Used by: docker compose up (root-level compose for all services)

# --- Supabase (shared by all services) ---
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_DB_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres

# --- Nest Recorder ---
GYM_ID=
TZ=America/New_York

# --- Processor ---
SCAN_ROOT=data/raw/nest
OUTPUT_ROOT=outputs
POLL_INTERVAL_SECONDS=30
# RUN_UNTIL=D6

# --- Uploader ---
SUPABASE_STORAGE_BUCKET=match-clips
UPLOADER_SCAN_ROOT=/app/outputs
UPLOADER_POLL_SECONDS=60
UPLOADER_DELETE_LOCAL=false
