# Processor Service Environment (.env.example)
# Copy to .env and set real values. Do NOT commit .env.

# --- Supabase connection (required for Stage F DB writes) ---
SUPABASE_URL=http://192.168.0.66:54321
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# --- Gym scope ---
# Set to restrict scanning to a single gym's recordings.
# If unset, scans all gyms under SCAN_ROOT.
GYM_ID=00000000-0000-0000-0000-000000000000

# --- Paths (defaults work for Docker volume mounts) ---
# SCAN_ROOT=data/raw/nest
# OUTPUT_ROOT=outputs

# --- Processing ---
# POLL_INTERVAL_SECONDS=30
# RUN_UNTIL=D6
